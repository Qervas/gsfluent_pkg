# gsfluent deployment env vars — per-machine config.
#
# QUICK START
#   1. cp .env.example .env
#   2. $EDITOR .env       # fill in the two REQUIRED paths below
#   3. ./start-gsfluent-server.sh
#
# .env is gitignored — your local paths never leave your machine.

# ====================================================================
# REQUIRED — fill these in before first launch.
# ====================================================================

# Path to your GaussianFluent source tree.
# Must contain: gs_simulation/watermelon/gs_simulation_building.py
# Don't have it? Clone from https://github.com/whc1992/GaussianFluent
# then apply our patches per tools/patches/UPSTREAM_PATCHES.md.
GSFLUENT_SIM_HOME=__FILL_ME_IN__/GaussianFluent

# Path to a Python interpreter with torch + warp 0.10 + taichi 1.5.
# This is usually a separate conda env from the gsfluent API.
# Example: /opt/conda/envs/GaussianFluent/bin/python
GSFLUENT_SIM_PYTHON=__FILL_ME_IN__/bin/python

# ====================================================================
# OPTIONAL — sensible defaults; uncomment to override.
# ====================================================================

# Path to the `gsfluent` CLI binary.
# Default: whatever `command -v gsfluent` resolves to (e.g. inside
# server/.venv/bin/ after ./setup-server.sh).
# GSFLUENT_BIN=/opt/conda/envs/gsfluent-api/bin/gsfluent

# ---- Network ----
# Port the API + bundled SPA listen on. All shipped launchers default
# to 18080 (so the README's firewall + curl examples line up). The
# Docker image's compose.yml uses BACKEND_PORT for the same concept.
# PORT=18080
# HOST=0.0.0.0

# Server log file. Defaults to /tmp/gsfluent_server.log.
# LOG_FILE=/var/log/gsfluent_server.log

# ---- Caches ----
# Where viser_headless stores downloaded model .ply blobs (~160 MB
# each). Defaults to <repo>/work/cache/model_files/ — override only if
# the repo lives on a small disk.
# GSFLUENT_MODEL_CACHE_DIR=/var/cache/gsfluent/model_files

# ---- Sim speed flags ----
# Set to 1 to re-enable --no_cfl_override + --graph_capture in run_sim.sh.
# Faster (~30-40%) but breaks scenarios with time-varying BCs (e.g.
# earthquake — see tools/recipes/RECIPES.md). Off by default.
# GSFLUENT_SIM_FAST=0
