# gsfluent deployment env vars.
#
# Copy this file to `.env` in the same directory, then fill in the paths
# for YOUR machine. The launchers (start-gsfluent-server.sh, run-server.sh)
# will source it automatically.
#
#   cp .env.example .env
#   $EDITOR .env
#   ./start-gsfluent-server.sh
#
# .env is gitignored — your local paths never leave your machine.

# ---- REQUIRED — sim environment ------------------------------------

# Path to the GaussianFluent source tree on this host.
# Must contain gs_simulation/watermelon/gs_simulation_building.py.
# Don't have it yet? Clone from https://github.com/whc1992/GaussianFluent
# then apply our patches per tools/patches/UPSTREAM_PATCHES.md.
GSFLUENT_SIM_HOME=/path/to/your/GaussianFluent

# Path to the Python interpreter that has torch + warp 0.10 + taichi 1.5
# installed. This is usually a separate conda env from the gsfluent API.
GSFLUENT_SIM_PYTHON=/path/to/your/sim-conda-env/bin/python

# ---- OPTIONAL — gsfluent API runtime --------------------------------

# Path to the `gsfluent` CLI binary. Defaults to whatever `command -v gsfluent`
# resolves to (e.g. inside server/.venv/bin/ after ./setup-server.sh).
# Override if you installed gsfluent in a different conda env.
# GSFLUENT_BIN=/path/to/your/api-conda-env/bin/gsfluent

# Network. Defaults: PORT=18080, HOST=0.0.0.0
# PORT=18080
# HOST=0.0.0.0

# Log file. Default: /tmp/gsfluent_server.log
# LOG_FILE=/var/log/gsfluent_server.log
