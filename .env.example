# gsfluent_pkg — deployment-local configuration template.
#
# Copy this file to `.env` and fill in the values for YOUR machine.
# `.env` is gitignored; nothing in this file ships in commits.
#
# Two scripts read it:
#   - scripts/_start.sh   (laptop side, started via `npm start`)
#   - tools/supervise.sh  (server side, started manually on the GPU host)

# ─── Shared backend (laptop side) ─────────────────────────────────────

# Public URL of the gsfluent API. The vite preview server bundled with
# `npm start` proxies the SPA's /api/* fetches here. If you're shipping
# the built dist/ to a static host with no proxy in front, set
# VITE_BACKEND_URL in frontend/.env.local instead (baked into the bundle
# at build time).
BACKEND_URL=http://your-backend:port

# SSH alias of the GPU host, used by any local script or doc example
# that pulls files from the server. Add an entry to ~/.ssh/config
# with this alias.
GSFLUENT_SSH_HOST=your-server

# ─── Server side (GPU host) ───────────────────────────────────────────
#
# Filesystem paths on the GPU host. The supervisor (tools/supervise.sh)
# uses these to find the simulation engine + Python interpreters. Leave
# empty on the laptop — they have no effect there.

# Root of your local checkout of this repo on the GPU host.
GSFLUENT_PKG_ROOT=/path/to/gsfluent_pkg

# Root of the GaussianFluent simulation engine on the GPU host (the
# `gs_simulation/` + `mpm_solver_warp/` source tree).
GSFLUENT_SIM_HOME=/path/to/GaussianFluent

# Python interpreter that has torch + warp + taichi installed. Used by
# tools/run_sim.sh to launch the MPM simulation.
GSFLUENT_SIM_PYTHON=/path/to/python

# Python interpreter that runs the v1 backend (`python -m gsfluent
# serve`). Can be the same as GSFLUENT_SIM_PYTHON if you have one env
# that satisfies both — but the backend only needs fastapi + uvicorn,
# so a lighter env is fine.
GSFLUENT_API_PYTHON=/path/to/python

# Public port the v1 backend binds. The supervisor passes this to
# `gsfluent serve --port`. Defaults to 7869.
GSFLUENT_BACKEND_PORT=7869
