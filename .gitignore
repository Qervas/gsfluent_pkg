.vscode/
.idea/
*.swp

# User data — never commit a 3DGS model
*.ply.large
# (do NOT ignore `core/` — that's our source code; only ignore user model dirs at top-level)
/model/

# Crash dumps — pattern with extension only, since we have a `core/` source dir.
core.[0-9]*

# Brainstorming companion artefacts
.superpowers/

# Vite build output bundled into the wheel; never committed.
server/gsfluent/static/

# Vite build output (client-served; strong split). Never committed.
frontend/dist/

