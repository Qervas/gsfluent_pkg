# Copy to .env.local in this directory to override defaults at build time.
# Vite reads VITE_-prefixed vars and inlines them at compile time, so a
# rebuild is required after edits.

# Points-mode WebSocket URL. The split-topology deployment serves Points
# frames from a local laptop service (tools/local_stream.py) rather than
# over WAN — pushing per-frame xyz at 30 fps would be ~1 Gbps over WAN.
# Default (when unset) is `ws(s)://<spa-origin>/api/stream`, i.e. the
# server's own /api/stream — useful for testing a server-bundled deploy.
VITE_LOCAL_STREAM_URL=ws://localhost:8083/api/stream

# Splats-mode viewer iframe (viser web client). Served by
# tools/viser_headless.py on the laptop.
VITE_VISER_URL=http://localhost:8091/

# Splats-mode control API (set cell/frame/camera). Sidecar to viser.
VITE_VISER_CONTROL_URL=http://localhost:8092

# If the SPA is served over https (e.g., behind a TLS-terminating reverse
# proxy), the browser refuses to load plain-http iframes / fetches as
# mixed content and the splat view silently breaks. Use the wss / https
# equivalents pointed at a TLS-terminated viser endpoint:
#   VITE_LOCAL_STREAM_URL=wss://laptop.example.com/local-stream
#   VITE_VISER_URL=https://laptop.example.com/viser/
#   VITE_VISER_CONTROL_URL=https://laptop.example.com/viser-control
