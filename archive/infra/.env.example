# gsfluent v2 environment
# Copy to infra/.env and fill in. Never commit infra/.env.

# --- exposure ---
# Caddy listens on this host port; routes /v1/* to api, /grafana/* to grafana, etc.
GSFLUENT_V2_PORT=8869

# --- postgres ---
POSTGRES_PASSWORD=changeme-postgres-strong
POSTGRES_PORT=15432

# --- redis ---
REDIS_PORT=16379

# --- minio (s3-compatible object store) ---
MINIO_ROOT_USER=gsfluent
MINIO_ROOT_PASSWORD=changeme-minio-strong
MINIO_API_PORT=19000
MINIO_CONSOLE_PORT=19001

# --- grafana ---
GRAFANA_ADMIN_PASSWORD=changeme-grafana-strong

# --- gpu ---
# Index of the GPU to dedicate to gsfluent-v2 workers (when added in Phase 3/5).
# Run `nvidia-smi --query-gpu=index,name --format=csv` to pick.
GSFLUENT_V2_GPU_INDEX=0

# --- sentry (sentry.io free tier; create projects, paste DSNs) ---
SENTRY_DSN_API=
SENTRY_DSN_FRONTEND=
